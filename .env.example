# Set true to preview the public storefront without PostgreSQL.
# Account, checkout, admin, and seller operations still require the database.
USE_MOCK_DATA="false"

# PostgreSQL connection string. Optional only when USE_MOCK_DATA=true.
# Use a dedicated database and least-privilege user for the full application.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ivory_store?schema=public"

# Generate with: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Public URL used in verification and reset-password emails.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional email delivery through Resend. Without this, links are logged only in development.
RESEND_API_KEY=""
EMAIL_FROM="IVORY <noreply@example.com>"

# Payment. Leave the server key empty to use the deterministic local mock provider.
MIDTRANS_SERVER_KEY=""
MIDTRANS_IS_PRODUCTION="false"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""

# Shipping. Leave the API key empty to use local mock courier rates/tracking.
BITESHIP_API_KEY=""
BITESHIP_BASE_URL="https://api.biteship.com/v1"
BITESHIP_ORIGIN_POSTAL_CODE="12950"

# Optional production image storage. Without all three values, consignment images use local disk.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Development seed credentials. Never reuse production credentials.
SEED_ADMIN_EMAIL="admin@example.test"
SEED_ADMIN_PASSWORD=""
SEED_CUSTOMER_EMAIL="customer@example.test"
SEED_CUSTOMER_PASSWORD=""
